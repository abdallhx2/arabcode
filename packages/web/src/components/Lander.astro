---
import { getRelativeLocaleUrl } from 'astro:i18n';

import CopyIcon from "../assets/lander/copy.svg";
import CheckIcon from "../assets/lander/check.svg";

const locale = Astro.currentLocale || 'root';
const homeHref = getRelativeLocaleUrl(locale, "");
const docsHref = getRelativeLocaleUrl(locale, "config");
const docsArHref = getRelativeLocaleUrl('ar', "");

const github = "https://github.com/abdallhx2/arabcode";
const installScript = "curl -fsSL https://raw.githubusercontent.com/abdallhx2/arabcode/main/install | bash";
---
<div class="lander" dir="rtl" lang="ar">

  <div class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href={homeHref}>
        <span class="glyph" aria-hidden="true">ع</span>
        <span class="wordmark" dir="ltr">arab<span class="dot">code</span></span>
      </a>
      <nav class="topbar-links" aria-label="روابط">
        <a class="docs-link" href={docsHref}>الوثائق</a>
        <a class="gh-pill" href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
    </div>
  </div>

  <section class="hero">
    <div class="wrap">
      <span class="eyebrow">الطرفية بالعربية الكاملة · RTL + تشكيل</span>
      <h1><span class="code-name">arabcode</span> — الذكاء الاصطناعي في طرفيّتك، بالعربية.</h1>
      <p class="tagline">أول أداة ذكاء اصطناعي للطرفية بعرضٍ عربي صحيح — اتجاه RTL وتشكيل وحروف متصلة. مبنية على محرّك opencode مفتوح المصدر.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={docsArHref}>ابدأ من الوثائق</a>
        <a class="btn btn-ghost" href={github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </div>
      <div class="cmd hero-cmd" dir="ltr">
        <button class="command" data-command={installScript}>
          <code><span class="tok-cmd">curl -fsSL </span><span class="tok-pkg">https://raw.githubusercontent.com/abdallhx2/arabcode/main/install</span> | bash</code>
          <span class="copy">
            <CopyIcon />
            <CheckIcon />
          </span>
        </button>
      </div>
    </div>
  </section>

  <section class="terminal-demo">
    <div class="wrap">
      <h2>هكذا تبدو الجلسة بالعربية</h2>
      <p class="lead">نصّ عربي متصل الحروف واتجاه صحيح، ومقاطع الكود تبقى LTR في مكانها.</p>
      <div class="term" dir="rtl" role="img" aria-label="جلسة طرفية بالعربية داخل أداة arabcode">
        <div class="term-bar">
          <span class="tb-dot"></span><span class="tb-dot"></span><span class="tb-dot"></span>
          <span class="tb-title" dir="ltr">arabcode — ~/my-app</span>
        </div>
        <div class="term-body">
          <p class="ln ltr"><span class="comment"># افتح مشروعك وشغّل الأداة</span></p>
          <p class="ln ltr"><span class="prompt">~/my-app $</span> arabcode</p>
          <p class="ln"><span class="who">أنت ›</span> اشرح لي كيف تُدار المصادقة في <span class="ltr">@src/auth.ts</span></p>
          <p class="ln"><span class="who">arabcode ›</span> <span class="ar-reply">تُدار المصادقة عبر وسيط يتحقق من التوكن في كل طلب، ثم يمرّر هوية المستخدم إلى بقية الدوال…</span></p>
          <p class="ln"><span class="comment">— اضغط Tab للتبديل بين وضعَي build و plan —</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="install">
    <div class="wrap">
      <h2>التثبيت</h2>
      <div class="install-grid">
        <div class="install-card">
          <h3 dir="ltr">npm</h3>
          <div class="cmd" dir="ltr">
            <button class="command" data-command="npm i -g arabcode">
              <code><span class="tok-cmd">npm i -g </span><span class="tok-pkg">arabcode</span></code>
              <span class="copy">
                <CopyIcon />
                <CheckIcon />
              </span>
            </button>
          </div>
        </div>
        <div class="install-card">
          <h3 dir="ltr">bun</h3>
          <div class="cmd" dir="ltr">
            <button class="command" data-command="bun i -g arabcode">
              <code><span class="tok-cmd">bun i -g </span><span class="tok-pkg">arabcode</span></code>
              <span class="copy">
                <CopyIcon />
                <CheckIcon />
              </span>
            </button>
          </div>
        </div>
        <div class="install-card">
          <h3>سكربت التثبيت</h3>
          <div class="cmd" dir="ltr">
            <button class="command" data-command={installScript}>
              <code><span class="tok-cmd">curl -fsSL </span><span class="tok-pkg">https://raw.githubusercontent.com/abdallhx2/arabcode/main/install</span> | bash</code>
              <span class="copy">
                <CopyIcon />
                <CheckIcon />
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="wrap">
      <span class="eyebrow">لماذا arabcode</span>
      <h2>قوّة أداة برمجة حديثة، بعربية تُقرأ كما ينبغي</h2>
      <div class="features-grid">
        <div class="card">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 7H4M20 12h-9M20 17h-6"/></svg>
            </span>
            <h3>عرض RTL صحيح</h3>
          </div>
          <p>اتجاه من اليمين لليسار وحروف عربية متصلة داخل أي طرفية.</p>
        </div>
        <div class="card">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M7 15h10M7 10.5h.01M11 10.5h.01M15 10.5h.01"/></svg>
            </span>
            <h3>إدخال عربي</h3>
          </div>
          <p>اكتب بالعربية مباشرة في الجلسة مع محاذاة منطقية للمؤشر.</p>
        </div>
        <div class="card">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="3 3"><rect x="4" y="5" width="16" height="14" rx="2"/><path stroke-dasharray="none" d="M8 10h8M8 14h5"/></svg>
            </span>
            <h3>تحديد ونسخ منطقي</h3>
          </div>
          <p>تحديد النص يتبع ترتيب القراءة لا ترتيب البايتات.</p>
        </div>
        <div class="card">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </span>
            <h3>أي طرفية</h3>
          </div>
          <p>يعمل في WezTerm وGhostty وKitty وAlacritty وغيرها.</p>
        </div>
        <div class="card">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.2 10.8 15.8 7.2M8.2 13.2l7.6 3.6"/></svg>
            </span>
            <h3>جلسات ومشاركة</h3>
          </div>
          <p>جلسات متوازية وروابط مشاركة عبر <code class="ltr">/share</code>.</p>
        </div>
        <div class="card highlight">
          <div class="card-title">
            <span class="chip" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6 2 12l6 6M16 6l6 6-6 6"/></svg>
            </span>
            <h3>مبني على opencode</h3>
          </div>
          <p>محرّك مفتوح المصدر برخصة MIT؛ طبقة العربية هي إسهام arabcode.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="foot">
    <div class="wrap foot-inner">
      <h2>جاهز؟</h2>
      <div class="foot-cta">
        <a class="btn btn-primary" href={docsArHref}>اقرأ الوثائق</a>
        <a class="btn btn-ghost" href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <p class="lineage">arabcode مبني على opencode مفتوح المصدر (MIT). الميزات الموروثة من المحرّك؛ إسهام arabcode هو طبقة العربية: الاتجاه والتشكيل والإدخال.</p>
      <p class="copyright" dir="ltr">© 2026 arabcode</p>
    </div>
  </section>

</div>

<style>
.lander {
  min-height: 100vh;
  background: var(--ac-bg) radial-gradient(circle at 1px 1px, var(--ac-grid) 1px, transparent 0);
  background-size: 26px 26px;
  color: var(--ac-text);
  font-family: var(--ac-font-ui);
}

.wrap {
  max-width: 1120px;
  margin-inline: auto;
  padding-inline: 20px;
}

/* ---------- shared ---------- */

.lander h2 {
  font-family: var(--ac-font-ui);
  font-size: clamp(1.3rem, 3vw, 1.7rem);
  font-weight: 800;
  color: var(--ac-text);
  line-height: 1.5;
}

.lead {
  margin-block-start: 0.5rem;
  color: var(--ac-text-dim);
  max-width: 60ch;
}

.eyebrow {
  display: block;
  font-family: var(--ac-font-ui);
  font-weight: 700;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0;
  color: var(--ac-accent-bright);
  margin-block-end: 0.8rem;
}

.btn {
  display: inline-block;
  padding: 0.62rem 1.15rem;
  border-radius: var(--ac-radius-sm);
  font-weight: 600;
  font-size: 0.95rem;
  line-height: 1.4;
  text-decoration: none;
  transition: background 0.15s ease, border-color 0.15s ease;
}
.btn-primary {
  background: var(--ac-accent);
  color: var(--ac-on-accent);
  border: 1px solid var(--ac-accent-deep);
}
.btn-primary:hover {
  background: var(--ac-accent-bright);
  color: var(--ac-on-accent);
}
.btn-ghost {
  border: 1px solid var(--ac-border);
  color: var(--ac-text);
}
.btn-ghost:hover {
  border-color: var(--ac-accent-deep);
  background: var(--ac-accent-soft);
  color: var(--ac-text);
}

/* command box + copy button */
.cmd {
  display: flex;
  align-items: center;
  background: var(--ac-code-bg);
  border: 1px solid var(--ac-border);
  border-radius: var(--ac-radius-sm);
  font-family: var(--ac-font-mono);
  padding: 0.55rem 0.9rem;
  overflow-x: auto;
}
.cmd .command {
  all: unset;
  display: flex;
  align-items: center;
  gap: 0.625rem;
  justify-content: space-between;
  cursor: pointer;
  width: 100%;
}
.cmd code {
  font-family: var(--ac-font-mono);
  font-size: 0.88rem;
  color: var(--ac-code-fg);
  white-space: nowrap;
}
.hero-cmd code { font-size: 0.78rem; white-space: normal; overflow-wrap: anywhere; line-height: 1.7; }
.cmd .tok-cmd { color: var(--ac-text-dim); }
.cmd .tok-pkg { color: var(--ac-accent-bright); font-weight: 600; }
.cmd .copy {
  line-height: 1;
  padding: 0;
  flex-shrink: 0;
}
.cmd .copy svg {
  width: 1rem;
  height: 1rem;
  vertical-align: middle;
}
.cmd .copy svg:first-child { color: var(--ac-muted); }
.cmd .copy svg:last-child { color: var(--ac-accent-bright); display: none; }
.cmd .command:hover .copy svg:first-child { color: var(--ac-text-dim); }
.cmd .command.success .copy { pointer-events: none; }
.cmd .command.success .copy svg:first-child { display: none; }
.cmd .command.success .copy svg:last-child { display: inline; }

/* ---------- (1) topbar ---------- */

.topbar {
  border-block-end: 1px solid var(--ac-hairline);
}
.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding-block: 0.8rem;
}
.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  text-decoration: none;
  color: var(--ac-text);
}
.brand .glyph {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border: 1px solid var(--ac-accent-deep);
  background: var(--ac-accent-soft);
  color: var(--ac-accent);
  border-radius: 6px;
  font-weight: 700;
  line-height: 1;
}
.brand .wordmark {
  font-family: var(--ac-font-mono);
  font-weight: 700;
  font-size: 1.05rem;
}
.brand .dot { color: var(--ac-accent); }
.topbar-links {
  display: flex;
  align-items: center;
  gap: 0.9rem;
}
.topbar-links a {
  text-decoration: none;
  font-size: 0.92rem;
  color: var(--ac-text-dim);
}
.topbar-links a.docs-link:hover { color: var(--ac-accent-bright); }
.topbar-links a.gh-pill {
  border: 1px solid var(--ac-border);
  border-radius: var(--ac-radius-sm);
  padding: 0.3rem 0.75rem;
  color: var(--ac-text);
  font-family: var(--ac-font-mono);
}
.topbar-links a.gh-pill:hover {
  border-color: var(--ac-accent-deep);
  background: var(--ac-accent-soft);
}

/* ---------- (2) hero ---------- */

.hero {
  position: relative;
  padding-block: clamp(2.6rem, 7vw, 5rem);
}
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(60% 55% at 82% 0%, var(--ac-accent-soft), transparent 70%);
  pointer-events: none;
}
.hero .wrap { position: relative; }
.hero h1 {
  font-family: var(--ac-font-ui);
  font-size: clamp(1.9rem, 5vw, 3rem);
  font-weight: 800;
  line-height: 1.6;
  max-width: 22ch;
  color: var(--ac-text);
}
.hero .code-name {
  font-family: var(--ac-font-mono);
  color: var(--ac-accent);
}
.hero .tagline {
  margin-block-start: 1rem;
  color: var(--ac-text-dim);
  font-size: 1.15rem;
  line-height: 1.9;
  max-width: 60ch;
}
.hero-cta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.8rem;
  margin-block-start: 1.8rem;
}
.hero-cmd {
  margin-block-start: 1.2rem;
  max-width: 620px;
}

/* ---------- (3) terminal demo ---------- */

.terminal-demo {
  border-block-start: 1px solid var(--ac-hairline);
  padding-block: clamp(2.2rem, 5vw, 3.6rem);
}

/* terminal mockup: pinned DARK in both themes (literals per spec §1.1) */
.term {
  margin-block-start: 1.2rem;
  background: #0a0806;
  border: 1px solid #2a2418;
  border-radius: 10px;
  box-shadow: 0 20px 50px -30px rgba(0, 0, 0, 0.9);
  font-family: var(--ac-font-mono);
  overflow: hidden;
}
.term-bar {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.55rem 0.9rem;
  background: #1b1710;
  border-block-end: 1px solid #2a2418;
}
.tb-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: #3a3226;
}
.tb-title {
  margin-inline-start: 0.5rem;
  font-size: 0.78rem;
  color: #7d766a;
}
.term-body {
  padding: 1rem 1.1rem;
  font-size: 0.92rem;
  line-height: 1.9;
  color: #ece7db;
}
.term-body .ln { margin: 0; }
.term-body .prompt { color: #ffaf00; }
.term-body .who { color: #ffc23d; font-weight: 600; }
.term-body .comment { color: #7d766a; }
.term-body .ln.ltr {
  display: block;
  direction: ltr;
  unicode-bidi: isolate;
  text-align: start;
}
.ltr {
  direction: ltr;
  unicode-bidi: isolate;
  display: inline-block;
}

/* ---------- (4) install ---------- */

.install {
  border-block-start: 1px solid var(--ac-hairline);
  padding-block: clamp(2.2rem, 5vw, 3.6rem);
}
.install-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1rem;
  margin-block-start: 1.2rem;
}
.install-card {
  background: var(--ac-panel);
  border: 1px solid var(--ac-border);
  border-radius: var(--ac-radius);
  padding: 1.1rem;
  min-width: 0;
}
.install-card h3 {
  font-family: var(--ac-font-mono);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--ac-text-dim);
  margin-block-end: 0.7rem;
  text-align: start;
}

/* ---------- (5) features ---------- */

.features {
  border-block-start: 1px solid var(--ac-hairline);
  padding-block: clamp(2.2rem, 5vw, 3.6rem);
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-block-start: 1.4rem;
}
.card {
  background: var(--ac-panel);
  border: 1px solid var(--ac-border);
  border-radius: var(--ac-radius);
  padding: 1.1rem;
  min-width: 0;
}
.card.highlight { border-color: var(--ac-accent-deep); }
.card-title {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  margin-block-end: 0.65rem;
}
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 34px;
  height: 34px;
  color: var(--ac-accent);
  background: var(--ac-accent-soft);
  border: 1px solid var(--ac-accent-line);
  border-radius: 8px;
}
.chip svg {
  width: 18px;
  height: 18px;
}
.card h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--ac-text);
}
.card p {
  color: var(--ac-text-dim);
  font-size: 0.92rem;
  line-height: 1.9;
}
.card p code.ltr {
  font-family: var(--ac-font-mono);
  font-size: 0.85em;
  color: var(--ac-accent-bright);
  background: var(--ac-elevated);
  border: 1px solid var(--ac-hairline);
  border-radius: 5px;
  padding: 0.05em 0.35em;
}

/* ---------- (6) foot ---------- */

.foot {
  border-block-start: 1px solid var(--ac-hairline);
  padding-block: clamp(2.2rem, 5vw, 3.6rem) 1.6rem;
}
.foot-inner { text-align: center; }
.foot h2 { font-size: clamp(1.4rem, 3.5vw, 1.9rem); }
.foot-cta {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-block-start: 1.2rem;
}
.foot .lineage {
  margin-block-start: 2.2rem;
  padding-block-start: 1.2rem;
  border-block-start: 1px solid var(--ac-hairline);
  color: var(--ac-muted);
  font-size: 0.9rem;
  line-height: 1.9;
}
.foot .copyright {
  margin-block-start: 0.4rem;
  color: var(--ac-muted);
  font-size: 0.85rem;
  font-family: var(--ac-font-mono);
}

/* ---------- responsive ---------- */

@media (max-width: 860px) {
  .features-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 620px) {
  .install-grid { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr; }
  .cmd code { white-space: normal; overflow-wrap: anywhere; }
}
</style>

<style is:global>
:root[data-has-hero] {
  header.header {
    display: none;
  }
  .main-frame {
    padding-top: 0;

    .main-pane > main {
      padding: 0;
    }
  }
  main > .content-panel .sl-markdown-content {
    margin-top: 0;
  }
}
</style>

<script>
  const buttons = document.querySelectorAll("button.command") as NodeListOf<HTMLButtonElement>

  buttons.forEach(button => {
    button.addEventListener("click", () => {
      navigator.clipboard.writeText(button.dataset.command!)
      button.classList.toggle("success")
      setTimeout(() => {
        button.classList.toggle("success");
      }, 1500)
    })
  })
</script>
